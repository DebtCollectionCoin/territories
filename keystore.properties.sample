# Sample keystore configuration for the Android release build.
# Copy this file to "keystore.properties" (gitignored) and fill in real values.
#
# Generate a keystore (one-time):
#   keytool -genkey -v \
#     -keystore release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias territories
#
# Place release.jks at the repository root (or use an absolute path below).

storeFile=release.jks
storePassword=CHANGE_ME
keyAlias=territories
keyPassword=CHANGE_ME
